{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Rynaro/APIVR-Delta/blob/v3.7.0/schemas/apivr-completion-report-profile.v1.json",
  "title": "ECL apivr-completion-report profile v1",
  "description": "Vendored from eidolons-ecl/schemas/per-eidolon/apivr-completion-report.v1.json (ECL v1.0.0). APIVR-Δ emit when work is complete; consumed by IDG. Contract: apivr-to-idg.yaml.",
  "allOf": [
    { "$ref": "_base-profile.v1.json" },
    {
      "type": "object",
      "required": ["files_changed_count", "tests_run", "tests_passed"],
      "properties": {
        "kind":    { "const": "apivr-completion-report" },
        "eidolon": { "const": "apivr" },
        "files_changed_count": { "type": "integer", "minimum": 0 },
        "tests_run":           { "type": "integer", "minimum": 0 },
        "tests_passed":        { "type": "integer", "minimum": 0 },
        "deltas_count":        { "type": "integer", "minimum": 0 },
        "escalations_count":   { "type": "integer", "minimum": 0 }
      }
    }
  ]
}
